// ── 子元件 ────────────────────────────────────────
function Tag({ color, children }) {
  return (
    <span style={{
      background:`${color}18`, border:`1px solid ${color}50`,
      color, fontSize:9, padding:"2px 7px", borderRadius:20,
      letterSpacing:1, fontFamily:"'Courier New',monospace",
    }}>
      {children}
    </span>
  );
}

function Card({ item, color, compact }) {
  const [hov, setHov] = useState(false);
  return (
    <div
      onMouseEnter={() => setHov(true)}
      onMouseLeave={() => setHov(false)}
      style={{
        background: hov ? "rgba(0,0,0,0.75)" : "rgba(0,0,0,0.45)",
        border: `1px solid ${hov ? color + "cc" : color + "35"}`,
        borderRadius: 8,
        padding: compact ? "5px 9px" : "9px 12px",
        minWidth: compact ? 100 : 120,
        cursor: "default",
        transform: hov ? "translateY(-2px)" : "none",
        boxShadow: hov ? `0 4px 18px ${color}28` : "none",
        transition: "all 0.18s",
      }}
    >
      <div style={{ display:"flex", alignItems:"center", gap:6 }}>
        {item.f && <span style={{ fontSize: compact ? 13 : 15 }}>{item.f}</span>}
        <div>
          <div style={{ color:"#fff", fontWeight:700, fontSize: compact ? 11 : 12, fontFamily:"'Courier New',monospace" }}>
            {item.n}
          </div>
          <div style={{ color, fontSize:10, fontWeight:600 }}>{item.t}</div>
        </div>
      </div>
      {!compact && item.r && (
        <div style={{ color:"#999", fontSize:10, marginTop:4, lineHeight:1.4 }}>{item.r}</div>
      )}
    </div>
  );
}

function DeepPanel({ deep, isOpen }) {
  if (!isOpen || !deep) return null;
  return (
    <div style={{
      marginTop: 12,
      padding: "14px 16px",
      background: "rgba(0,0,0,0.35)",
      border: `1px dashed ${deep.color}50`,
      borderRadius: 10,
      animation: "fadeIn 0.3s ease",
    }}>
      <div style={{ color:deep.color, fontSize:12, fontWeight:700, marginBottom:12, letterSpacing:0.5 }}>
        {deep.title}
      </div>
      {deep.groups.map((g, i) => (
        <div key={i} style={{ marginBottom:14 }}>
          <div style={{ display:"flex", alignItems:"flex-start", gap:8, marginBottom:6, flexWrap:"wrap" }}>
            <span style={{ color:"#ccc", fontSize:11, fontWeight:700 }}>{g.label}</span>
            {g.note && (
              <span style={{
                color:"#888", fontSize:10, fontStyle:"italic",
                background:"rgba(255,200,0,0.07)",
                border:"1px solid rgba(255,200,0,0.15)",
                borderRadius:4, padding:"1px 6px",
              }}>
                💡 {g.note}
              </span>
            )}
          </div>
          <div style={{ display:"flex", flexWrap:"wrap", gap:7 }}>
            {g.items.map((c, j) => (
              <div key={j} style={{
                background:`${deep.color}10`,
                border:`1px solid ${deep.color}35`,
                borderRadius:7, padding:"5px 10px",
              }}>
                <span style={{ color:"#fff", fontWeight:700, fontSize:11, fontFamily:"'Courier New',monospace" }}>{c.n}</span>
                <span style={{ color:deep.color, marginLeft:5, fontSize:10 }}>{c.t}</span>
                {c.r && <div style={{ color:"#888", fontSize:10, marginTop:2 }}>{c.r}</div>}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  );
}

// ── 主組件 ────────────────────────────────────────
export default function App() {
  const [expanded, setExpanded] = useState({ e3: true });
  const [deepOpen, setDeepOpen] = useState({});

  const toggleExpand = id => setExpanded(p => ({ ...p, [id]: !p[id] }));
  const toggleDeep   = id => setDeepOpen(p => ({ ...p, [id]: !p[id] }));

  return (
    <div style={{
      minHeight: "100vh",
      background: "#050b18",
      color: "#fff",
      fontFamily: "Georgia, serif",
      padding: "20px 14px 40px",
      backgroundImage:`
        radial-gradient(ellipse at 15% 5%, rgba(0,212,255,0.06) 0%,transparent 45%),
        radial-gradient(ellipse at 85% 95%, rgba(168,85,247,0.06) 0%,transparent 45%),
        linear-gradient(rgba(0,212,255,0.025) 1px,transparent 1px),
        linear-gradient(90deg,rgba(0,212,255,0.025) 1px,transparent 1px)
      `,
      backgroundSize: "100% 100%,100% 100%,44px 44px,44px 44px",
    }}>
      {/* Header */}
      <div style={{ textAlign:"center", marginBottom:28 }}>
        <div style={{ color:"#00d4ff", fontSize:10, letterSpacing:6, fontFamily:"'Courier New',monospace", marginBottom:6 }}>
          NVIDIA GTC 2025 ✦ JENSEN HUANG'S FIVE-LAYER CAKE
        </div>
        <h1 style={{
          fontSize:"clamp(18px,4vw,30px)", fontWeight:900, margin:0,
          background:"linear-gradient(135deg,#00d4ff 0%,#a855f7 50%,#ec4899 100%)",
          WebkitBackgroundClip:"text", WebkitTextFillColor:"transparent",
          backgroundClip:"text",
        }}>
          AI供應鏈深度地圖 × 五層蛋糕理論
        </h1>
        <p style={{ color:"#555", fontSize:12, marginTop:6, fontFamily:"'Courier New',monospace" }}>
          美股驅動 → 五層蛋糕 → 台股受惠　｜　點擊「🔬深挖」展開上游原物料週邊
        </p>
      </div>

      <div style={{ maxWidth:1000, margin:"0 auto" }}>
        {LAYERS.map((layer, idx) => {
          const open  = !!expanded[layer.id];
          const dOpen = !!deepOpen[layer.id];

          return (
            <div key={layer.id}>
              {/* Arrow connector */}
              {idx > 0 && (
                <div style={{ display:"flex", flexDirection:"column", alignItems:"center", margin:"3px 0" }}>
                  <div style={{ width:2, height:18, background:`linear-gradient(to bottom,${LAYERS[idx-1].color}60,${layer.color})` }} />
                  <div style={{ width:0, height:0, borderLeft:"5px solid transparent", borderRight:"5px solid transparent", borderTop:`9px solid ${layer.color}` }} />
                </div>
              )}

              {/* Layer card */}
              <div style={{
                background:`${layer.color}07`,
                border:`1px solid ${layer.color}40`,
                borderRadius:14,
                padding:"14px 16px",
              }}>
                {/* Header */}
                <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", gap:8, marginBottom:10, flexWrap:"wrap" }}>
                  <div style={{ flex:1 }}>
                    <div style={{ display:"flex", alignItems:"center", gap:8, flexWrap:"wrap" }}>
                      <h2 style={{ margin:0, fontSize:"clamp(13px,3vw,16px)", fontWeight:800, color:layer.color }}>
                        {layer.icon} {layer.label}
                      </h2>
                      {layer.cake && <Tag color={layer.color}>{layer.cake}</Tag>}
                    </div>
                    <div style={{ color:"#777", fontSize:11, marginTop:2, fontFamily:"'Courier New',monospace" }}>{layer.sub}</div>
                    {layer.desc && (
                      <div style={{ color:"#555", fontSize:10, marginTop:3, fontStyle:"italic" }}>「{layer.desc}」</div>
                    )}
                  </div>
                  <div style={{ display:"flex", gap:8, alignItems:"center", flexShrink:0 }}>
                    {layer.deep && (
                      <button
                        onClick={() => toggleDeep(layer.id)}
                        style={{
                          background: dOpen ? `${layer.color}25` : "rgba(255,255,255,0.05)",
                          border: `1px solid ${layer.color}60`,
                          color: layer.color, fontSize:11, padding:"4px 12px",
                          borderRadius:20, cursor:"pointer", letterSpacing:0.5,
                          transition:"all 0.2s",
                        }}
                      >
                        🔬 深挖 {dOpen ? "▲" : "▼"}
                      </button>
                    )}
                    <button
                      onClick={() => toggleExpand(layer.id)}
                      style={{
                        background:"rgba(255,255,255,0.04)",
                        border:"1px solid rgba(255,255,255,0.15)",
                        color:"#aaa", fontSize:11, padding:"4px 12px",
                        borderRadius:20, cursor:"pointer",
                      }}
                    >
                      {open ? "收合" : "展開"}
                    </button>
                  </div>
                </div>

                {/* Companies */}
                {layer.subs ? (
                  <div style={{ display:"flex", flexDirection:"column", gap:10 }}>
                    {layer.subs.map(s => (
                      <div key={s.label}>
                        <div style={{ color:layer.color, fontSize:10, letterSpacing:2, marginBottom:6, fontFamily:"'Courier New',monospace", opacity:0.8 }}>
                          {s.label}
                        </div>
                        <div style={{ display:"flex", flexWrap:"wrap", gap:7 }}>
                          {s.companies.map(c => <Card key={c.t+c.n} item={c} color={layer.color} compact={!open} />)}
                        </div>
                      </div>
                    ))}
                  </div>
                ) : (
                  <div style={{ display:"flex", flexWrap:"wrap", gap:7 }}>
                    {layer.companies.map(c => <Card key={c.t+c.n} item={c} color={layer.color} compact={!open} />)}
                  </div>
                )}

                {/* Deep panel */}
                <DeepPanel deep={layer.deep} isOpen={dOpen} />
              </div>
            </div>
          );
        })}

        {/* Footer */}
        <div style={{
          marginTop:28, padding:"14px 18px",
          background:"rgba(255,255,255,0.02)",
          border:"1px solid rgba(255,255,255,0.07)",
          borderRadius:12,
        }}>
          <div style={{ display:"flex", flexWrap:"wrap", gap:16 }}>
            <div style={{ flex:1, minWidth:180 }}>
              <div style={{ color:"#00d4ff", fontSize:11, marginBottom:3 }}>📊 資料來源</div>
              <div style={{ color:"#444", fontSize:10, lineHeight:1.6 }}>
                國泰投信・玉山投顧・理財周刊・財報狗・數位時代・iThome・TechNews（2025–2026）
              </div>
            </div>
            <div style={{ flex:1, minWidth:180 }}>
              <div style={{ color:"#f59e0b", fontSize:11, marginBottom:3 }}>⚠️ 免責聲明</div>
              <div style={{ color:"#444", fontSize:10, lineHeight:1.6 }}>
                本圖僅供教育研究參考，不構成任何投資建議。投資有風險，請自行評估。
              </div>
            </div>
            <div style={{ flex:1, minWidth:180 }}>
              <div style={{ color:"#22c55e", fontSize:11, marginBottom:3 }}>💡 操作說明</div>
              <div style={{ color:"#444", fontSize:10, lineHeight:1.6 }}>
                點「🔬深挖」展開原物料週邊 ｜ 點「展開/收合」切換公司詳情
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
